# === PRODUCTION CONFIGURATION ===

# App
PORT=4000
NODE_ENV=production
CLIENT_URL=https://your-vercel-domain.vercel.app

# MongoDB (Atlas - requis pour production)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio-mariam

# JWT (clé longue et complexe)
JWT_SECRET=votre_clé_secrète_très_longue_et_complexe_minimum_32_caractères
JWT_EXPIRES_IN=7d

# SMTP (Gmail ou autre service)
# Pour Gmail: utiliser un mot de passe d'application (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
MAIL_FROM="Portfolio Mariam <votre-email@gmail.com>"
MAIL_TO="votre-email-personnel@gmail.com"
