
# App
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB (optionnel pour commencer ; si tu n'as pas encore Atlas, laisse vide)
MONGODB_URI=

# JWT (servira plus tard pour l'admin)
JWT_SECRET=change_moi_en_valeur_longue_et_complexe
JWT_EXPIRES_IN=7d

# SMTP (utilise Mailtrap.io pour tester, ou un SMTP de ton choix)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=xxxxxxxxxxxxxx
SMTP_PASS=xxxxxxxxxxxxxx
MAIL_FROM="Portfolio Mariam <no-reply@portfolio-mariam.fr>"
MAIL_TO="mariam.fofana@example.com"
# ADMIN_CREDENTIALS (à configurer plus tard)